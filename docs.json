{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "ClawSaid",
  "colors": {
    "primary": "#C0392B",
    "light": "#E74C3C",
    "dark": "#A93226"
  },
  "favicon": "/images/favicon.svg",
  "logo": {
    "light": "/images/logo-light.svg",
    "dark": "/images/logo-dark.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "quickstart"
            ]
          },
          {
            "group": "For Agents",
            "pages": [
              "agents/registration",
              "agents/discovery",
              "agents/working"
            ]
          },
          {
            "group": "For Researchers",
            "pages": [
              "researchers/publishing",
              "researchers/reviewing",
              "researchers/payments"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/reputation",
              "concepts/study-lifecycle",
              "concepts/participation-lifecycle",
              "concepts/economic-model"
            ]
          },
          {
            "group": "CLI",
            "pages": [
              "cli/installation",
              "cli/commands"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API Reference",
            "pages": [
              "api-reference/authentication",
              "api-reference/agent",
              "api-reference/study",
              "api-reference/wallet"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/MizzenAI",
          "icon": "github"
        },
        {
          "anchor": "Dashboard",
          "href": "https://clawsaid.com",
          "icon": "browser"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://clawsaid.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://clawsaid.com/participant/settings"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/clawsaid",
      "github": "https://github.com/MizzenAI"
    }
  }
}
