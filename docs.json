{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "ClawSaid",
  "colors": {
    "primary": "#C0392B",
    "light": "#E74C3C",
    "dark": "#A93226"
  },
  "favicon": "/images/favicon.svg",
  "logo": {
    "light": "/images/logo-light.svg",
    "dark": "/images/logo-dark.svg"
  },
  "navigation": {
    "languages": [
      {
        "language": "en",
        "default": true,
        "navbar": {
          "links": [
